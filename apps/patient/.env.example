# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# ─── LiveKit (video consultations) ────────────────────────────────────────────
# Found in: https://cloud.livekit.io → your project → settings
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# ─── Mapbox (emergency map) ───────────────────────────────────────────────────
# Found in: https://account.mapbox.com/access-tokens
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Paynow (Zimbabwe payments) ───────────────────────────────────────────────
# Found in: https://www.paynow.co.zw → Integrations
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
# Vercel URL of this app — used as Paynow callback/return targets
PAYNOW_RESULT_URL=https://your-patient-app.vercel.app/api/payments/callback
PAYNOW_RETURN_URL=https://your-patient-app.vercel.app/book?payment=complete

# ─── Cross-app links ──────────────────────────────────────────────────────────
NEXT_PUBLIC_DOCTOR_APP_URL=https://your-doctor-app.vercel.app
